{
  "name": "pow-graph",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/server.ts src/incremental-update.ts --bundle --platform=node --format=esm --outdir=dist --external:node:* --external:@modelcontextprotocol/* --external:web-tree-sitter --external:tree-sitter-javascript --external:tree-sitter-typescript",
    "build:watch": "npm run build -- --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
